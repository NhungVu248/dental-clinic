generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ───────────────────────────────────────────────────

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  users UserRole[]
}

model User {
  id            Int      @id @default(autoincrement())
  fullName      String
  username      String   @unique
  email         String   @unique
  password      String
  isActive      Boolean  @default(true)
  lockReason    String?
  loginAttempts Int      @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  logs          SystemLog[]
  certificates  UserCertificate[]
  serviceGroups ServiceGroupDoctor[]
  priceLogs     ServicePrice[]       @relation("PriceCreator")
  doctorSchedules  DoctorSchedule[]  @relation("DoctorSchedules")
  createdSchedules DoctorSchedule[]  @relation("ScheduleCreator")
  createdHolidays  Holiday[]         @relation("HolidayCreator")

  // Profile theo vai trò
  adminProfile       AdminProfile?
  receptionistProfile ReceptionistProfile?
  accountantProfile  AccountantProfile?
  doctorProfile      DoctorProfile?
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  detail    String?  @db.Text
  ip        String?
  status    String   @default("SUCCESS")   // SUCCESS | FAILED
  module    String?                         // Auth | User | Service
  createdAt DateTime @default(now())
}

// ─── USER CERTIFICATES ──────────────────────────────────────

model UserCertificate {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename     String   // stored filename on disk (uuid-based)
  originalName String   // original file name from upload
  mimetype     String
  size         Int
  uploadedAt   DateTime @default(now())
}

// ─── ADMIN PROFILE ──────────────────────────────────────────

model AdminProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn quản trị
  specialization   String?
  degree           String?
  educationLevel   String?
  graduatedSchool  String?
  graduationYear   Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  systemPermissions     Json?
  languages             Json?

  // Công việc
  employmentStatus String?   // working | on_leave | resigned | inactive
  position         String?
  department       String?
  branch           String?
  workType         String?   // full_time | part_time | collaborator
  startDate        DateTime?
  endDate          DateTime?
  contractNumber   String?
  workingNote      String?   @db.Text

  // Hồ sơ đính kèm
  qualificationFiles Json?
  identityFiles      Json?
  contractFiles      Json?
  profileDocuments   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── RECEPTIONIST PROFILE ───────────────────────────────────

model ReceptionistProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn lễ tân
  educationLevel       String?
  graduatedSchool      String?
  graduationYear       Int?
  yearsOfExperience    Int?
  professionalSkills   Json?
  languages            Json?
  computerSkills       Json?
  customerServiceLevel String?  // basic | good | advanced

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ACCOUNTANT PROFILE ─────────────────────────────────────

model AccountantProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn kế toán
  specialization        String?   // kế toán tổng hợp, kế toán thuế...
  degree                String?
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  softwareSkills        Json?     // phần mềm kế toán
  languages             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DOCTOR PROFILE ─────────────────────────────────────────

model DoctorProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn bác sĩ
  specialization     String?
  degree             String?
  educationLevel     String?
  graduatedSchool    String?
  graduationYear     Int?
  licenseNumber      String?  @unique
  licenseIssueDate   DateTime?
  licenseExpiryDate  DateTime?
  yearsOfExperience  Int?
  professionalSkills Json?
  servicesCanPerform Json?
  languages          Json?

  // Công việc
  employmentStatus  String?   // working | on_leave | resigned | inactive
  position          String?
  workType          String?   // full_time | part_time | collaborator
  startDate         DateTime?
  endDate           DateTime?
  contractNumber    String?

  // Lịch làm việc
  scheduleType            String?   // fixed | rotating | custom
  workingDays             Json?
  shiftStart              String?
  shiftEnd                String?
  maxAppointmentsPerDay   Int?
  appointmentDuration     Int?
  isAvailableOnline       Boolean   @default(false)

  // Tài chính
  baseSalary        Decimal?  @db.Decimal(12, 2)
  salaryType        String?   // monthly | per_shift | percentage
  commissionRate    Decimal?  @db.Decimal(5, 2)
  bankAccountName   String?
  bankName          String?
  bankAccountNumber String?
  taxCode           String?
  insuranceNumber   String? 

  // Hồ sơ đính kèm
  qualificationFiles Json?
  licenseFiles       Json?
  identityFiles      Json?
  contractFiles      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DỊCH VỤ NHA KHOA ───────────────────────────────────────

model ServiceGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors   ServiceGroupDoctor[]
  services  Service[]
  schedules DoctorSchedule[]
}

model ServiceGroupDoctor {
  id             Int          @id @default(autoincrement())
  serviceGroupId Int
  doctorId       Int
  serviceGroup   ServiceGroup @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  doctor         User         @relation(fields: [doctorId], references: [id])

  @@unique([serviceGroupId, doctorId])
}

model Service {
  id             Int            @id @default(autoincrement())
  code           String         @unique
  name           String
  description    String?        @db.Text
  duration       Int            @default(0)   // thời lượng thực hiện (phút, 0 = chưa cấu hình)
  status         String         @default("INACTIVE") // INACTIVE | ACTIVE | SUSPENDED | DISCONTINUED
  usageCount     Int            @default(0)
  activatedAt    DateTime?
  serviceGroupId Int
  serviceGroup   ServiceGroup   @relation(fields: [serviceGroupId], references: [id])
  prices         ServicePrice[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// ─── BẢNG GIÁ DỊCH VỤ ───────────────────────────────────────

model ServicePrice {
  id          Int       @id @default(autoincrement())
  serviceId   Int
  service     Service   @relation(fields: [serviceId], references: [id])
  basePrice   Int       // VND, no decimals
  discountPct Float     @default(0) // 0.0 – 100.0
  startDate   DateTime
  endDate     DateTime? // null = no expiry
  createdBy   Int?
  creator     User?     @relation("PriceCreator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─── SMS THÔNG BÁO (UC10) ────────────────────────────────────

/// Singleton cấu hình SMS gateway (always id = 1)
model SmsConfig {
  id          Int      @id
  isEnabled   Boolean  @default(true)
  provider    String   @default("VIETTEL") // VIETTEL | ESMS | TWILIO | OTHER
  apiKey      String?  @db.Text
  secretKey   String?  @db.Text            // eSMS SecretKey / Twilio Auth Token
  brandname   String   @default("DentCare")
  dailyLimit  Int      @default(500)
  quietStart  String   @default("21:00")  // HH:MM – bắt đầu giờ im lặng
  quietEnd    String   @default("07:00")  // HH:MM – kết thúc giờ im lặng
  updatedAt   DateTime @updatedAt
}

/// Mẫu nội dung SMS cho từng loại sự kiện
model SmsTemplate {
  id        Int      @id @default(autoincrement())
  type      String   @unique // CONFIRM_BOOKING | REMINDER_24H | REMINDER_2H | CANCEL | RESCHEDULE
  name      String
  content   String   @db.Text
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Log mỗi tin SMS đã / đang / thất bại gửi
model SmsLog {
  id            Int       @id @default(autoincrement())
  recipientName String?
  phone         String
  type          String
  status        String    @default("PENDING") // PENDING | SUCCESS | FAILED
  content       String    @db.Text
  retryCount    Int       @default(0)
  errorMsg      String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())
}

// ─── NGÀY NGHỈ LỄ (UC07) ────────────────────────────────────

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  startDate   DateTime // date-only, stored at UTC midnight
  endDate     DateTime // inclusive end date
  type        String   @default("NATIONAL") // NATIONAL | PRIVATE | RECURRING
  sendSms     Boolean  @default(false)
  autoCancel  Boolean  @default(false)
  createdBy   Int?
  creator     User?    @relation("HolidayCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CA LÀM VIỆC (UC06) ──────────────────────────────────────

model WorkShift {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  startTime    String   // "HH:MM"
  endTime      String   // "HH:MM"
  slotDuration Int      // phút / lịch hẹn (tối thiểu 10)
  bufferTime   Int      @default(0)  // phút đệm giữa hai lịch hẹn (0/5/10/15)
  maxPatients  Int      // số BN tối đa / bác sĩ / ca
  reserveSlots Int      @default(1)  // slot dự phòng cấp cứu giữ lại / bác sĩ / ca
  applyDays    Json     // [2,3,4,5,6] – 2=T2(Mon)…7=T7(Sat), 0=CN(Sun)
  isActive     Boolean  @default(true)
  colorCode    String   @default("blue") // blue|green|purple|orange|red|teal|pink
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  schedules    DoctorSchedule[]
}

// ─── LỊCH TRỰC BÁC SĨ (UC08) ─────────────────────────────────

model DoctorSchedule {
  id             Int           @id @default(autoincrement())
  doctorId       Int
  doctor         User          @relation("DoctorSchedules", fields: [doctorId], references: [id])
  shiftId        Int
  shift          WorkShift     @relation(fields: [shiftId], references: [id])
  workDate       DateTime      // UTC midnight của ngày làm việc
  serviceGroupId Int?
  serviceGroup   ServiceGroup? @relation(fields: [serviceGroupId], references: [id], onDelete: SetNull)
  note           String?       @db.Text
  isOverride     Boolean       @default(false) // Admin override khẩn cấp (E3)
  createdBy      Int?
  creator        User?         @relation("ScheduleCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([doctorId, shiftId, workDate])
}