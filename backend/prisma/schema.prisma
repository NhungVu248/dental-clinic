generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AccountantProfile {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique(map: "AccountantProfile_userId_key")
  phone                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?   @db.Text
  avatar                String?
  nationalId            String?
  issueDate             DateTime?
  issuePlace            String?
  hometown              String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?   @db.Text
  specialization        String?
  degree                String?
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  softwareSkills        Json?
  languages             Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "AccountantProfile_userId_fkey")

  @@map("accountantprofile")
}

model AdminProfile {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique(map: "AdminProfile_userId_key")
  phone                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?   @db.Text
  avatar                String?
  nationalId            String?
  issueDate             DateTime?
  issuePlace            String?
  hometown              String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?   @db.Text
  specialization        String?
  degree                String?
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  systemPermissions     Json?
  languages             Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  branch                String?
  contractFiles         Json?
  contractNumber        String?
  department            String?
  employmentStatus      String?
  endDate               DateTime?
  identityFiles         Json?
  position              String?
  profileDocuments      Json?
  qualificationFiles    Json?
  startDate             DateTime?
  workType              String?
  workingNote           String?   @db.Text
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "AdminProfile_userId_fkey")

  @@map("adminprofile")
}

model Appointment {
  id                               Int       @id @default(autoincrement())
  code                             String    @unique(map: "Appointment_code_key")
  patientName                      String
  patientPhone                     String
  patientDob                       DateTime?
  patientGender                    String?
  note                             String?   @db.LongText
  cancelReason                     String?   @db.LongText
  doctorId                         Int?
  serviceId                        Int?
  appointmentDate                  DateTime
  status                           String    @default("PENDING")
  createdBy                        Int?
  createdAt                        DateTime  @default(now())
  updatedAt                        DateTime  @updatedAt
  creator                          User?     @relation("appointment_createdByTouser", fields: [createdBy], references: [id], map: "Appointment_createdBy_fkey")
  doctor                           User?     @relation("appointment_doctorIdTouser", fields: [doctorId], references: [id], map: "Appointment_doctorId_fkey")
  service                          Service?  @relation(fields: [serviceId], references: [id], map: "Appointment_serviceId_fkey")

  @@index([appointmentDate], map: "Appointment_appointmentDate_idx")
  @@index([createdBy], map: "Appointment_createdBy_fkey")
  @@index([doctorId], map: "Appointment_doctorId_fkey")
  @@index([patientPhone], map: "Appointment_patientPhone_idx")
  @@index([serviceId], map: "Appointment_serviceId_fkey")
  @@index([status], map: "Appointment_status_idx")
  @@map("appointment")
}

model DoctorProfile {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique(map: "DoctorProfile_userId_key")
  phone                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?   @db.Text
  avatar                String?
  nationalId            String?
  issueDate             DateTime?
  issuePlace            String?
  hometown              String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?   @db.Text
  specialization        String?
  degree                String?
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  licenseNumber         String?   @unique(map: "DoctorProfile_licenseNumber_key")
  licenseIssueDate      DateTime?
  licenseExpiryDate     DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  servicesCanPerform    Json?
  languages             Json?
  employmentStatus      String?
  position              String?
  workType              String?
  startDate             DateTime?
  endDate               DateTime?
  contractNumber        String?
  scheduleType          String?
  workingDays           Json?
  shiftStart            String?
  shiftEnd              String?
  maxAppointmentsPerDay Int?
  appointmentDuration   Int?
  isAvailableOnline     Boolean   @default(false)
  baseSalary            Decimal?  @db.Decimal(12, 2)
  salaryType            String?
  commissionRate        Decimal?  @db.Decimal(5, 2)
  bankAccountName       String?
  bankName              String?
  bankAccountNumber     String?
  taxCode               String?
  insuranceNumber       String?
  qualificationFiles    Json?
  licenseFiles          Json?
  identityFiles         Json?
  contractFiles         Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "DoctorProfile_userId_fkey")

  @@map("doctorprofile")
}

model DoctorSchedule {
  id             Int           @id @default(autoincrement())
  doctorId       Int
  shiftId        Int
  workDate       DateTime
  serviceGroupId Int?
  note           String?       @db.Text
  isOverride     Boolean       @default(false)
  createdBy      Int?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime  @updatedAt
  createdByUser  User?         @relation("doctorschedule_createdByTouser", fields: [createdBy], references: [id], map: "DoctorSchedule_createdBy_fkey")
  doctor         User          @relation("doctorschedule_doctorIdTouser", fields: [doctorId], references: [id], map: "DoctorSchedule_doctorId_fkey")
  serviceGroup   ServiceGroup? @relation(fields: [serviceGroupId], references: [id], map: "DoctorSchedule_serviceGroupId_fkey")
  shift          WorkShift     @relation(fields: [shiftId], references: [id], map: "DoctorSchedule_shiftId_fkey")

  @@unique([doctorId, shiftId, workDate], map: "DoctorSchedule_doctorId_shiftId_workDate_key")
  @@index([createdBy], map: "DoctorSchedule_createdBy_fkey")
  @@index([serviceGroupId], map: "DoctorSchedule_serviceGroupId_fkey")
  @@index([shiftId], map: "DoctorSchedule_shiftId_fkey")
  @@map("doctorschedule")
}

model Holiday {
  id         Int      @id @default(autoincrement())
  name       String
  startDate  DateTime
  endDate    DateTime
  type       String   @default("NATIONAL")
  sendSms    Boolean  @default(false)
  autoCancel Boolean  @default(false)
  /// Giá» báº¯t Ä‘áº§u nghá»‰ "HH:MM" â€” chá»‰ dÃ¹ng cho PRIVATE / RECURRING; null = cáº£ ngÃ y
  startTime  String?  @db.VarChar(5)
  /// Giá» káº¿t thÃºc nghá»‰ "HH:MM" â€” chá»‰ dÃ¹ng cho PRIVATE / RECURRING; null = cáº£ ngÃ y
  endTime    String?  @db.VarChar(5)
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime  @updatedAt
  user       User?    @relation(fields: [createdBy], references: [id], map: "Holiday_createdBy_fkey")

  @@index([createdBy], map: "Holiday_createdBy_fkey")
  @@index([startDate], map: "Holiday_startDate_idx")
  @@map("holiday")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique(map: "PasswordResetToken_token_key")
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "PasswordResetToken_userId_fkey")

  @@index([userId], map: "PasswordResetToken_userId_fkey")
  @@map("passwordresettoken")
}

model ReceptionistProfile {
  id                    Int       @id @default(autoincrement())
  userId                Int       @unique(map: "ReceptionistProfile_userId_key")
  phone                 String?
  gender                String?
  dateOfBirth           DateTime?
  address               String?   @db.Text
  avatar                String?
  nationalId            String?
  issueDate             DateTime?
  issuePlace            String?
  hometown              String?
  maritalStatus         String?
  emergencyContactName  String?
  emergencyContactPhone String?
  notes                 String?   @db.Text
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  yearsOfExperience     Int?
  professionalSkills    Json?
  languages             Json?
  computerSkills        Json?
  customerServiceLevel  String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ReceptionistProfile_userId_fkey")

  @@map("receptionistprofile")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique(map: "RefreshToken_token_key") @db.VarChar(500)
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "RefreshToken_userId_fkey")

  @@index([userId], map: "RefreshToken_userId_fkey")
  @@map("refreshtoken")
}

model Role {
  id       Int        @id @default(autoincrement())
  name     String     @unique(map: "Role_name_key")
  userRoles UserRole[]

  @@map("role")
}

model Service {
  id             Int            @id @default(autoincrement())
  code           String         @unique(map: "Service_code_key")
  name           String
  description    String?        @db.Text
  duration       Int            @default(0)
  serviceGroupId Int
  createdAt      DateTime       @default(now())
  updatedAt      DateTime  @updatedAt
  activatedAt    DateTime?
  status         String         @default("INACTIVE")
  usageCount     Int            @default(0)
  appointments   Appointment[]
  serviceGroup   ServiceGroup   @relation(fields: [serviceGroupId], references: [id], map: "Service_serviceGroupId_fkey")
  servicePrices  ServicePrice[]

  @@index([serviceGroupId], map: "Service_serviceGroupId_fkey")
  @@map("service")
}

model ServiceGroup {
  id                  Int                  @id @default(autoincrement())
  name                String               @unique(map: "ServiceGroup_name_key")
  description         String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime  @updatedAt
  doctorSchedules     DoctorSchedule[]
  services            Service[]
  doctors             ServiceGroupDoctor[]

  @@map("servicegroup")
}

model ServiceGroupDoctor {
  id             Int          @id @default(autoincrement())
  serviceGroupId Int
  doctorId       Int
  doctor         User         @relation(fields: [doctorId], references: [id], map: "ServiceGroupDoctor_doctorId_fkey")
  serviceGroup   ServiceGroup @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade, map: "ServiceGroupDoctor_serviceGroupId_fkey")

  @@unique([serviceGroupId, doctorId], map: "ServiceGroupDoctor_serviceGroupId_doctorId_key")
  @@index([doctorId], map: "ServiceGroupDoctor_doctorId_fkey")
  @@map("servicegroupdoctor")
}

model ServicePrice {
  id          Int       @id @default(autoincrement())
  serviceId   Int
  basePrice   Int
  discountPct Float     @default(0)
  startDate   DateTime
  endDate     DateTime?
  createdBy   Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdByUser User?   @relation(fields: [createdBy], references: [id], map: "ServicePrice_createdBy_fkey")
  service     Service   @relation(fields: [serviceId], references: [id], map: "ServicePrice_serviceId_fkey")

  @@index([createdBy], map: "ServicePrice_createdBy_fkey")
  @@index([serviceId], map: "ServicePrice_serviceId_fkey")
  @@map("serviceprice")
}

model SmsConfig {
  id         Int      @id
  isEnabled  Boolean  @default(true)
  provider   String   @default("VIETTEL")
  apiKey     String?  @db.Text
  brandname  String   @default("DentCare")
  dailyLimit Int      @default(500)
  quietStart String   @default("21:00") @db.VarChar(10)
  quietEnd   String   @default("07:00") @db.VarChar(10)
  updatedAt  DateTime  @updatedAt
  secretKey  String?  @db.LongText

  @@map("smsconfig")
}

model SmsLog {
  id            Int       @id @default(autoincrement())
  recipientName String?
  phone         String
  type          String
  status        String    @default("PENDING")
  content       String    @db.Text
  retryCount    Int       @default(0)
  errorMsg      String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([createdAt], map: "SmsLog_createdAt_idx")
  @@index([status], map: "SmsLog_status_idx")
  @@map("smslog")
}

model SmsTemplate {
  id        Int      @id @default(autoincrement())
  type      String   @unique(map: "SmsTemplate_type_key")
  name      String
  content   String   @db.Text
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)
  updatedAt DateTime  @updatedAt

  @@map("smstemplate")
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  detail    String?  @db.Text
  ip        String?
  createdAt DateTime @default(now())
  module    String?
  status    String   @default("SUCCESS")
  user      User?    @relation(fields: [userId], references: [id], map: "SystemLog_userId_fkey")

  @@index([userId], map: "SystemLog_userId_fkey")
  @@map("systemlog")
}

model User {
  id                         Int                  @id @default(autoincrement())
  fullName                   String
  username                   String               @unique(map: "User_username_key")
  email                      String               @unique(map: "User_email_key")
  password                   String
  isActive                   Boolean              @default(true)
  loginAttempts              Int                  @default(0)
  lockedUntil                DateTime?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime  @updatedAt
  lockReason                 String?
  accountantProfile          AccountantProfile?
  adminProfile               AdminProfile?
  appointmentsCreated        Appointment[]        @relation("appointment_createdByTouser")
  appointmentsAsDoctor       Appointment[]        @relation("appointment_doctorIdTouser")
  doctorProfile              DoctorProfile?
  doctorSchedulesCreated     DoctorSchedule[]     @relation("doctorschedule_createdByTouser")
  doctorSchedules            DoctorSchedule[]     @relation("doctorschedule_doctorIdTouser")
  holidays                   Holiday[]
  passwordResetTokens        PasswordResetToken[]
  receptionistProfile        ReceptionistProfile?
  refreshTokens              RefreshToken[]
  serviceGroups              ServiceGroupDoctor[]
  servicePrices              ServicePrice[]
  logs                       SystemLog[]
  userCertificates           UserCertificate[]
  roles                      UserRole[]

  @@map("user")
}

model UserCertificate {
  id           Int      @id @default(autoincrement())
  userId       Int
  filename     String
  originalName String
  mimetype     String
  size         Int
  uploadedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserCertificate_userId_fkey")

  @@index([userId], map: "UserCertificate_userId_fkey")
  @@map("usercertificate")
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  role   Role @relation(fields: [roleId], references: [id], map: "UserRole_roleId_fkey")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserRole_userId_fkey")

  @@unique([userId, roleId], map: "UserRole_userId_roleId_key")
  @@index([roleId], map: "UserRole_roleId_fkey")
  @@map("userrole")
}

model WorkShift {
  id             Int              @id @default(autoincrement())
  name           String           @unique(map: "WorkShift_name_key")
  startTime      String
  endTime        String
  slotDuration   Int
  bufferTime     Int              @default(0)
  maxPatients    Int
  reserveSlots   Int              @default(1)
  applyDays      Json
  isActive       Boolean          @default(true)
  colorCode      String           @default("blue")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime  @updatedAt
  doctorSchedules DoctorSchedule[]

  @@map("workshift")
}
