generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ───────────────────────────────────────────────────

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique
  users UserRole[]
}

model User {
  id            Int      @id @default(autoincrement())
  fullName      String
  username      String   @unique
  email         String   @unique
  password      String
  isActive      Boolean  @default(true)
  lockReason    String?
  loginAttempts Int      @default(0)
  lockedUntil   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  roles         UserRole[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  logs          SystemLog[]
  certificates  UserCertificate[]
  serviceGroups ServiceGroupDoctor[]
  priceLogs     ServicePrice[]       @relation("PriceCreator")

  // Profile theo vai trò
  adminProfile       AdminProfile?
  receptionistProfile ReceptionistProfile?
  accountantProfile  AccountantProfile?
  doctorProfile      DoctorProfile?
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(500)
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  detail    String?  @db.Text
  ip        String?
  status    String   @default("SUCCESS")   // SUCCESS | FAILED
  module    String?                         // Auth | User | Service
  createdAt DateTime @default(now())
}

// ─── USER CERTIFICATES ──────────────────────────────────────

model UserCertificate {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename     String   // stored filename on disk (uuid-based)
  originalName String   // original file name from upload
  mimetype     String
  size         Int
  uploadedAt   DateTime @default(now())
}

// ─── ADMIN PROFILE ──────────────────────────────────────────

model AdminProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn quản trị
  specialization   String?
  degree           String?
  educationLevel   String?
  graduatedSchool  String?
  graduationYear   Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  systemPermissions     Json?
  languages             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── RECEPTIONIST PROFILE ───────────────────────────────────

model ReceptionistProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn lễ tân
  educationLevel       String?
  graduatedSchool      String?
  graduationYear       Int?
  yearsOfExperience    Int?
  professionalSkills   Json?
  languages            Json?
  computerSkills       Json?
  customerServiceLevel String?  // basic | good | advanced

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ACCOUNTANT PROFILE ─────────────────────────────────────

model AccountantProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn kế toán
  specialization        String?   // kế toán tổng hợp, kế toán thuế...
  degree                String?
  educationLevel        String?
  graduatedSchool       String?
  graduationYear        Int?
  certificateNumber     String?
  certificateIssueDate  DateTime?
  certificateExpiryDate DateTime?
  yearsOfExperience     Int?
  professionalSkills    Json?
  softwareSkills        Json?     // phần mềm kế toán
  languages             Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DOCTOR PROFILE ─────────────────────────────────────────

model DoctorProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Định danh
  phone       String?
  gender      String?
  dateOfBirth DateTime?
  address     String?  @db.Text
  avatar      String?

  // Hành chính
  nationalId  String?
  issueDate   DateTime?
  issuePlace  String?
  hometown    String?
  maritalStatus             String?
  emergencyContactName      String?
  emergencyContactPhone     String?
  notes       String?  @db.Text

  // Chuyên môn bác sĩ
  specialization     String?
  degree             String?
  educationLevel     String?
  graduatedSchool    String?
  graduationYear     Int?
  licenseNumber      String?  @unique
  licenseIssueDate   DateTime?
  licenseExpiryDate  DateTime?
  yearsOfExperience  Int?
  professionalSkills Json?
  servicesCanPerform Json?
  languages          Json?

  // Công việc
  employmentStatus  String?   // working | on_leave | resigned | inactive
  position          String?
  workType          String?   // full_time | part_time | collaborator
  startDate         DateTime?
  endDate           DateTime?
  contractNumber    String?

  // Lịch làm việc
  scheduleType            String?   // fixed | rotating | custom
  workingDays             Json?
  shiftStart              String?
  shiftEnd                String?
  maxAppointmentsPerDay   Int?
  appointmentDuration     Int?
  isAvailableOnline       Boolean   @default(false)

  // Tài chính
  baseSalary        Decimal?  @db.Decimal(12, 2)
  salaryType        String?   // monthly | per_shift | percentage
  commissionRate    Decimal?  @db.Decimal(5, 2)
  bankAccountName   String?
  bankName          String?
  bankAccountNumber String?
  taxCode           String?
  insuranceNumber   String? 

  // Hồ sơ đính kèm
  qualificationFiles Json?
  licenseFiles       Json?
  identityFiles      Json?
  contractFiles      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── DỊCH VỤ NHA KHOA ───────────────────────────────────────

model ServiceGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors  ServiceGroupDoctor[]
  services Service[]
}

model ServiceGroupDoctor {
  id             Int          @id @default(autoincrement())
  serviceGroupId Int
  doctorId       Int
  serviceGroup   ServiceGroup @relation(fields: [serviceGroupId], references: [id], onDelete: Cascade)
  doctor         User         @relation(fields: [doctorId], references: [id])

  @@unique([serviceGroupId, doctorId])
}

model Service {
  id             Int            @id @default(autoincrement())
  code           String         @unique
  name           String
  description    String?        @db.Text
  status         String         @default("INACTIVE") // INACTIVE | ACTIVE | SUSPENDED | DISCONTINUED
  usageCount     Int            @default(0)
  activatedAt    DateTime?
  serviceGroupId Int
  serviceGroup   ServiceGroup   @relation(fields: [serviceGroupId], references: [id])
  prices         ServicePrice[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// ─── BẢNG GIÁ DỊCH VỤ ───────────────────────────────────────

model ServicePrice {
  id          Int       @id @default(autoincrement())
  serviceId   Int
  service     Service   @relation(fields: [serviceId], references: [id])
  basePrice   Int       // VND, no decimals
  discountPct Float     @default(0) // 0.0 – 100.0
  startDate   DateTime
  endDate     DateTime? // null = no expiry
  createdBy   Int?
  creator     User?     @relation("PriceCreator", fields: [createdBy], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}